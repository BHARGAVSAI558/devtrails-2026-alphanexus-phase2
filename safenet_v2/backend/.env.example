# Supabase: Project Settings → Database → URI (use "Transaction" pooler for serverless if you prefer).
# Async driver must be asyncpg — use postgresql:// or postgres://; the app rewrites to postgresql+asyncpg://.
# Append ?ssl=require if your host requires TLS (common on Supabase direct connections).
DATABASE_URL=postgresql+asyncpg://postgres:PASS@db.REF.supabase.co:5432/postgres
JWT_SECRET=
ADMIN_JWT_SECRET=
OPENWEATHER_API_KEY=
OPENAQ_API_KEY=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
TOMTOM_API_KEY=
NEWSAPI_KEY=
GEMINI_API_KEY=
# Hosted Postgres: leave DEMO_MODE=false so startup does not create demo phone users (9999999999 / 8888888888).
DEMO_MODE=false
# Comma-separated browser origins (admin Vite + Expo web). Match your live Vercel URLs exactly (no trailing slash).
ALLOWED_ORIGINS=https://safenet-sage.vercel.app,https://safenet-admin-wine.vercel.app
