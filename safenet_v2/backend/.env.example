# Supabase: Project Settings → Database → URI (pooler or direct).
# Use postgres:// or postgresql:// or postgresql+asyncpg:// — the app normalizes to postgresql+asyncpg://.
# If the URI contains sslmode= (e.g. ?sslmode=require), it is removed for asyncpg and TLS is set via connect_args['ssl'].
# On *.supabase.co / pooler.supabase.com, TLS is enabled even when sslmode is omitted.
DATABASE_URL=postgresql+asyncpg://postgres:PASS@db.REF.supabase.co:5432/postgres?sslmode=require
JWT_SECRET=
ADMIN_JWT_SECRET=
OPENWEATHER_API_KEY=
OPENAQ_API_KEY=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
TOMTOM_API_KEY=
NEWSAPI_KEY=
GEMINI_API_KEY=
# Hosted Postgres: leave DEMO_MODE=false so startup does not create demo phone users (9999999999 / 8888888888).
DEMO_MODE=false
# Comma-separated browser Origins (trimmed, trailing slashes stripped, deduped). Omitted/malformed env still merges required live URLs in app/core/config.py.
ALLOWED_ORIGINS=https://safenet-sage.vercel.app,https://safenet-admin-wine.vercel.app,http://localhost:3000,http://localhost:5173,http://localhost:8081,http://127.0.0.1:3000,http://127.0.0.1:5173,http://127.0.0.1:8081
