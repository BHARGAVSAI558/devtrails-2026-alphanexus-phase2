{
  "expo": {
    "name": "SafeNet",
    "slug": "safenet",
    "version": "1.0.1",
    "orientation": "portrait",
    "scheme": "safenet",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1A56DB"
    },
    "android": {
      "package": "com.alphanexus.safenet",
      "versionCode": 2,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1A56DB"
      }
    },
    "ios": {
      "bundleIdentifier": "com.alphanexus.safenet",
      "buildNumber": "2",
      "supportsTablet": false
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/icon.png"
    },
    "extra": {
      "BACKEND_URL": "https://safenet-api-y4se.onrender.com",
      "BACKEND_URL_DEV": "remote",
      "DEMO_MODE": true,
      "eas": {
        "projectId": "2d45889e-9415-4966-be7f-ba2711a57f13"
      }
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ]
    ],
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/2d45889e-9415-4966-be7f-ba2711a57f13"
    }
  }
}
